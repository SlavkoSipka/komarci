{
  "name": "welfare-gh-pages",
  "version": "1.0.0",
  "description": "Welfare - Charity Website Template",
  "main": "index.html",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run sass:watch\" \"npm run serve\"",
    "serve": "http-server -p 3000 -c-1 -o",
    "sass:watch": "sass --watch scss:css --style expanded --source-map",
    "sass:build": "sass scss:css --style compressed --no-source-map",
    "build": "npm run sass:build",
    "start": "npm run dev",
    "clean": "rimraf css/style.css css/style.css.map",
    "format": "prettier --write \"**/*.{html,css,scss,js,json}\"",
    "lint:scss": "stylelint \"scss/**/*.scss\" --fix"
  },
  "keywords": [
    "charity",
    "welfare",
    "nonprofit",
    "donation",
    "bootstrap",
    "template"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "sass": "^1.69.7",
    "stylelint": "^16.1.0",
    "stylelint-config-standard-scss": "^13.0.0"
  },
  "browserslist": [
    "last 5 versions",
    "> 1%",
    "not dead"
  ]
}
